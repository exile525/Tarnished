  <property name="styleSheet">
   <string notr="true">/* 全局背景 — 与智能家居界面一致 */
QWidget#AiChatWidget {
    background-color: #e6f7ff;
}

/* 全局标签样式 */
QLabel {
    font: 11pt &quot;Microsoft YaHei&quot;;
    color: #333333;
}

/* 聊天内容区域 — 白色背景，浅灰边框，圆角 */
QTextBrowser#textBrowser_chat {
    background-color: white;
    border: 1px solid #dcdfe6;
    border-radius: 10px;
    padding: 10px;
    font: 11pt &quot;Microsoft YaHei&quot;;
    color: #333333;
}

/* 输入框（备用） */
QTextEdit {
    background-color: white;
    border: 1px solid #dcdfe6;
    border-radius: 10px;
    padding: 8px 12px;
    font: 11pt &quot;Microsoft YaHei&quot;;
    color: #333333;
}
QTextEdit:focus {
    border-color: #409eff;
}

/* 通用按钮 — 与家居界面按钮完全一致 */
QPushButton {
    background-color: #409eff;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 6px 12px;
    font: 10pt &quot;Microsoft YaHei&quot;;
}
QPushButton:hover {
    background-color: #66b1ff;
}
QPushButton:pressed {
    background-color: #337ecc;
}

/* 录音按钮 — 继承通用按钮样式，可通过额外属性突出（但保持风格统一） */
QPushButton#pushButton_record {
    background-color: #409eff;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 6px 12px;
    font: 10pt &quot;Microsoft YaHei&quot;;
}
QPushButton#pushButton_record:hover {
    background-color: #66b1ff;
}
QPushButton#pushButton_record:pressed {
    background-color: #337ecc;
}

/* 断开云端按钮 — 警示色，保持家居界面中的红/暖色习惯 */
QPushButton#pushButton_disconnect {
    background-color: #f56c6c;
}
QPushButton#pushButton_disconnect:hover {
    background-color: #f78989;
}
QPushButton#pushButton_disconnect:pressed {
    background-color: #dd6161;
}

/* 返回主界面按钮 — 次要按钮，使用中性色 */
QPushButton#pushButton_back {
    background-color: #909399;
}
QPushButton#pushButton_back:hover {
    background-color: #a6a9ad;
}
QPushButton#pushButton_back:pressed {
    background-color: #7e8186;
}

/* 标题栏 — 与家居界面顶部文字风格统一 */
QLabel#label_title {
    background-color: transparent;
    border-bottom: 1px solid #dcdfe6;
    font: 14pt &quot;Microsoft YaHei&quot;;
    font-weight: bold;
    color: #2c3e50;
}</string>
